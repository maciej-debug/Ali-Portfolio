---
import BaseLayout from "../components/layout/BaseLayout.astro";
// Note: URL param pre-fill is handled client-side (this is a static site)
---

<BaseLayout
  title="Contact — Ali Bachler"
  description="Get in touch with Alexandra Bachler to enquire about artworks, commissions, or collaborations."
>

  <!-- ── Page Header ────────────────────────────────────────────────────────── -->
  <div class="page-header">
    <div class="page-header__inner">
      <p class="about__label">Get in touch</p>
      <h1 class="page-header__title">Contact</h1>
    </div>
  </div>

  <!-- ── Contact Split Layout ──────────────────────────────────────────────── -->
  <section class="contact-section">
    <div class="contact-section__inner">

      <!-- Left: Info -->
      <div class="contact-info">
        <div class="contact-info__block">
          <p class="about__label">Email</p>
          <a href="mailto:hi@alexandrabachler.at" class="contact-info__value">
            hi@alexandrabachler.at
          </a>
        </div>

        <div class="contact-info__block">
          <p class="about__label">Instagram</p>
          <a
            href="https://instagram.com/coloursofali"
            class="contact-info__value"
            target="_blank"
            rel="noopener noreferrer"
          >@coloursofali</a>
        </div>

        <div class="contact-info__block">
          <p class="about__label">Location</p>
          <p class="contact-info__text">Ericeira, Portugal</p>
        </div>

        <div class="contact-info__note">
          <p>
            I typically reply within 1–2 business days. For urgent enquiries,
            feel free to email directly.
          </p>
          <p style="margin-top: 12px;">
            Shipment is handled via DHL or FedEx unless agreed otherwise and
            is not included in the artwork price.
          </p>
        </div>
      </div>

      <!-- Right: Form -->
      <div class="contact-form-wrap">
        <div id="form-wrapper">
          <form
            class="inquiry-form"
            id="contact-form"
            novalidate
          >
            <input type="hidden" name="access_key" value="db38074e-e4fd-467c-aa55-e31aa77b869f" />
            <input type="hidden" name="subject" value="New enquiry — alexandrabachler.at" />
            <input type="hidden" name="from_name" value="Ali Bachler Website" />
            <div class="form-row">
              <div class="form-field">
                <label for="contact-name" class="form-label">Name *</label>
                <input
                  type="text"
                  id="contact-name"
                  name="name"
                  class="form-input"
                  placeholder="Your name"
                  required
                  autocomplete="name"
                />
              </div>
              <div class="form-field">
                <label for="contact-email" class="form-label">Email *</label>
                <input
                  type="email"
                  id="contact-email"
                  name="email"
                  class="form-input"
                  placeholder="your@email.com"
                  required
                  autocomplete="email"
                />
              </div>
            </div>

            <div class="form-field">
              <label for="contact-artwork" class="form-label">Artwork (optional)</label>
              <input
                type="text"
                id="contact-artwork"
                name="artwork"
                class="form-input"
                placeholder="Name of the artwork you're interested in"
              />
            </div>

            <div class="form-field">
              <label for="contact-subject" class="form-label">Subject</label>
              <select id="contact-subject" name="subject" class="form-select form-input">
                <option value="artwork-enquiry">Artwork enquiry</option>
                <option value="commission">Commission enquiry</option>
                <option value="other">Other</option>
              </select>
            </div>

            <div class="form-field">
              <label for="contact-message" class="form-label">Message *</label>
              <textarea
                id="contact-message"
                name="message"
                class="form-textarea"
                placeholder="Tell me what you have in mind…"
                required
                rows="6"
              ></textarea>
            </div>

            <div id="form-error" style="display:none; color: var(--accent); font-size: 14px; margin-top: -8px;" aria-live="polite"></div>

            <button type="submit" class="btn btn--primary" id="submit-btn">
              Send message <span aria-hidden="true">→</span>
            </button>
          </form>
        </div>

        <!-- Success state (shown after submission) -->
        <div class="form-success" id="form-success" style="display: none;" aria-live="polite">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--sage)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="20 6 9 17 4 12"></polyline>
          </svg>
          <h2 class="form-success__title">Message sent</h2>
          <p class="form-success__body">
            Thank you for reaching out. I'll get back to you within 1–2 business days.
          </p>
          <a href="/artworks" class="btn btn--outline" style="margin-top: 8px;">Browse works</a>
        </div>
      </div>

    </div>
  </section>

</BaseLayout>

<style>
  .contact-section {
    padding: 64px var(--section-h) var(--section-v);
  }

  .contact-section__inner {
    max-width: var(--max-width);
    margin-inline: auto;
    display: grid;
    grid-template-columns: 320px 1fr;
    gap: 80px;
    align-items: start;
  }

  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 32px;
    position: sticky;
    top: calc(var(--nav-height) + 32px);
  }

  .contact-info__block {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .contact-info__value {
    font-size: 15px;
    color: var(--text-100);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .contact-info__value:hover {
    color: var(--text);
  }

  .contact-info__text {
    font-size: 15px;
    color: var(--text-100);
  }

  .contact-info__note {
    padding-top: 24px;
    border-top: 1px solid var(--border);
    font-size: 14px;
    font-weight: 300;
    color: var(--text-200);
    line-height: 1.7;
  }

  .contact-form-wrap {
    max-width: 600px;
  }

  @media (max-width: 900px) {
    .contact-section__inner {
      grid-template-columns: 1fr;
      gap: 48px;
    }

    .contact-info {
      position: static;
    }
  }

  @media (max-width: 640px) {
    .contact-section {
      padding: 40px var(--section-h) var(--section-v);
    }
  }
</style>

<script>
  // ── Pre-fill from URL params (runs client-side since this is static SSG) ───
  (function () {
    const params   = new URLSearchParams(window.location.search);
    const artwork  = params.get("artwork") ?? "";
    const type     = params.get("type")    ?? "";

    const artworkField  = document.getElementById("contact-artwork")  as HTMLInputElement | null;
    const subjectField  = document.getElementById("contact-subject")  as HTMLSelectElement | null;
    const messageField  = document.getElementById("contact-message")  as HTMLTextAreaElement | null;

    if (artworkField && artwork) {
      artworkField.value = artwork;
    }

    if (subjectField && type === "commission") {
      subjectField.value = "commission";
    }

    if (messageField && artwork && !messageField.value) {
      if (type === "commission") {
        messageField.value = `Hi Ali,\n\nI'm interested in commissioning a piece similar to "${artwork}".\n\nBest,`;
      } else {
        messageField.value = `Hi Ali,\n\nI'm interested in "${artwork}" and would love to know more about availability and pricing.\n\nBest,`;
      }
    }
  })();

  const form      = document.getElementById("contact-form")  as HTMLFormElement | null;
  const wrapper   = document.getElementById("form-wrapper")  as HTMLElement | null;
  const success   = document.getElementById("form-success")  as HTMLElement | null;
  const errorBox  = document.getElementById("form-error")    as HTMLElement | null;
  const submitBtn = document.getElementById("submit-btn")    as HTMLButtonElement | null;

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (!form || !submitBtn) return;

    // Basic client-side validation
    const name    = (form.querySelector("#contact-name")    as HTMLInputElement)?.value.trim();
    const email   = (form.querySelector("#contact-email")   as HTMLInputElement)?.value.trim();
    const message = (form.querySelector("#contact-message") as HTMLTextAreaElement)?.value.trim();

    if (!name || !email || !message) {
      showError("Please fill in all required fields.");
      return;
    }
    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      showError("Please enter a valid email address.");
      return;
    }

    hideError();
    submitBtn.textContent = "Sending…";
    submitBtn.disabled = true;

    try {
      const data = Object.fromEntries(new FormData(form));

      const res = await fetch("https://api.web3forms.com/submit", {
        method: "POST",
        headers: { "Content-Type": "application/json", "Accept": "application/json" },
        body: JSON.stringify({
          access_key: "db38074e-e4fd-467c-aa55-e31aa77b869f",
          ...data,
        }),
      });

      const json = await res.json();
      if (!res.ok || !json.success) throw new Error(json.message || "Submission failed");

      // Show success
      if (wrapper) wrapper.style.display = "none";
      if (success) success.style.removeProperty("display");

    } catch {
      showError("Something went wrong. Please try emailing directly at hi@alexandrabachler.at");
      submitBtn.textContent = "Send message →";
      submitBtn.disabled = false;
    }
  });

  function showError(msg: string) {
    if (errorBox) {
      errorBox.textContent = msg;
      errorBox.style.removeProperty("display");
    }
  }

  function hideError() {
    if (errorBox) errorBox.style.display = "none";
  }
</script>
