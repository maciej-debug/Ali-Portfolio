    <div class="footer__top">
      <div class="footer__brand">
        <span class="footer__name">Ali Bachler</span>
        <span class="footer__location">Ericeira, Portugal</span>
      </div>

      <nav class="footer__links" aria-label="Footer links">
        <a href="/artworks" class="footer__link">Works</a>
        <a href="/#about" class="footer__link">About</a>
        <a href="/contact" class="footer__link">Contact</a>
        <a
          href="https://instagram.com/coloursofali"
          class="footer__link"
          target="_blank"
          rel="noopener noreferrer"
        >@coloursofali</a>
        <a
          href="mailto:hi@alexandrabachler.at"
          class="footer__link"
        >hi@alexandrabachler.at</a>
      </nav>
    </div>

    <p class="footer__bottom">
      Photography by Dominika Jaworska &amp; Maciej Chmielewski. &copy; {year} Alexandra Bachler. All rights reserved.
    </p>
