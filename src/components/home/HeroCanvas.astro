---
// HeroCanvas — Ink Bloom interactive canvas background for the hero.
// Sits as an absolute layer behind all hero text.
// Palette is chosen randomly on each page load; override with
// data-palette="warm|earth|bloom|moss" on the .hero element.
---

<canvas id="hero-canvas" aria-hidden="true"></canvas>

<style>
  #hero-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
    pointer-events: none; /* hero element owns pointer events */
  }
</style>

<script>
(function () {
  /* ── Palettes ──────────────────────────────────────────── */
  const PALETTES = {
    warm:  { bg: '#faf8f5', inks: ['#6b4a32','#c87856','#d89450','#8fa03a','#a8c4d8'] },
    earth: { bg: '#ede4d3', inks: ['#4a3524','#a85a3a','#c07838','#6a7a2a','#b7b298'] },
    bloom: { bg: '#f6ece4', inks: ['#7a3a2a','#d77a55','#e7b7a3','#c88a6a','#a8c4d8'] },
    moss:  { bg: '#eeece0', inks: ['#3a4420','#7a8a30','#b5a85a','#5a6030','#a8b8a0'] },
  };
  const PALETTE_KEYS = Object.keys(PALETTES);
  const INTENSITY = 0.7;
  const SPEED     = 0.85;

  /* ── Pick palette ─────────────────────────────────────── */
  const hero = document.querySelector('.hero');
  const cv   = document.getElementById('hero-canvas');
  if (!hero || !cv) return;

  const override = hero.dataset.palette;
  const palKey   = (override && PALETTES[override])
    ? override
    : PALETTE_KEYS[Math.floor(Math.random() * PALETTE_KEYS.length)];
  const PAL = PALETTES[palKey];

  // Paint the hero background to match the palette paper colour
  hero.style.backgroundColor = PAL.bg;

  /* ── Canvas setup ─────────────────────────────────────── */
  const ctx = cv.getContext('2d');
  let W = 0, H = 0;
  const dpr = Math.min(2, window.devicePixelRatio || 1);

  function resize() {
    const r = hero.getBoundingClientRect();
    W = r.width;
    H = r.height;
    cv.width  = W * dpr;
    cv.height = H * dpr;
    cv.style.width  = W + 'px';
    cv.style.height = H + 'px';
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    ctx.fillStyle = PAL.bg;
    ctx.fillRect(0, 0, W, H);
  }

  /* ── Helpers ──────────────────────────────────────────── */
  function hexA(hex, a) {
    const n = hex.replace('#', '');
    const r = parseInt(n.substr(0, 2), 16);
    const g = parseInt(n.substr(2, 2), 16);
    const b = parseInt(n.substr(4, 2), 16);
    return `rgba(${r},${g},${b},${a.toFixed(4)})`;
  }

  /* ── Bloom state ──────────────────────────────────────── */
  const blooms = [];

  function makeShape() {
    const lobes = 7 + Math.floor(Math.random() * 5);
    const pts = [];
    for (let i = 0; i < lobes; i++) {
      const a = (i / lobes) * Math.PI * 2 + (Math.random() - 0.5) * 0.18;
      pts.push({ a, r: 0.82 + Math.random() * 0.32 });
    }
    return pts;
  }

  function addBloom(x, y, big = false) {
    const wetIdx = Math.floor(Math.random() * PAL.inks.length);
    blooms.push({
      x, y,
      r:     big ? 14 : 6,
      tr:    (big ? 240 : 100) * (0.75 + Math.random() * 0.7) * INTENSITY,
      wet:   PAL.inks[wetIdx],
      life:  1,
      decay: 0.008 + Math.random() * 0.006,
      wobble: Math.random() * Math.PI * 2,
      shape: makeShape(),
      rot:   Math.random() * Math.PI * 2,
    });
    if (blooms.length > 160) blooms.shift();
  }

  function seed() {
    for (let i = 0; i < 4; i++) addBloom(Math.random() * W, Math.random() * H, true);
  }

  function blobPath(b, rMul) {
    const pts = b.shape, n = pts.length, r = b.r * rMul;
    const abs = pts.map(p => {
      const a  = p.a + b.rot;
      const rr = r * p.r * (0.96 + Math.sin(a * 2 + b.wobble) * 0.04);
      return { x: b.x + Math.cos(a) * rr, y: b.y + Math.sin(a) * rr };
    });
    ctx.beginPath();
    for (let i = 0; i < n; i++) {
      const p0 = abs[(i - 1 + n) % n];
      const p1 = abs[i];
      const p2 = abs[(i + 1) % n];
      const p3 = abs[(i + 2) % n];
      if (i === 0) ctx.moveTo(p1.x, p1.y);
      const c1x = p1.x + (p2.x - p0.x) / 6, c1y = p1.y + (p2.y - p0.y) / 6;
      const c2x = p2.x - (p3.x - p1.x) / 6, c2y = p2.y - (p3.y - p1.y) / 6;
      ctx.bezierCurveTo(c1x, c1y, c2x, c2y, p2.x, p2.y);
    }
    ctx.closePath();
  }

  /* ── Pointer state ────────────────────────────────────── */
  const mouse = { x: 0.5, y: 0.5, px: 0.5, py: 0.5, moved: false };
  const purge = { active: 0 };

  /* ── AbortController for clean removal ───────────────── */
  const ac = new AbortController();
  const sig = { signal: ac.signal };

  // Pointer listeners on the HERO element
  hero.addEventListener('pointermove', e => {
    const rect = hero.getBoundingClientRect();
    mouse.x = (e.clientX - rect.left) / rect.width;
    mouse.y = (e.clientY - rect.top)  / rect.height;
    mouse.moved = true;
  }, sig);

  hero.addEventListener('click', e => {
    const rect = hero.getBoundingClientRect();
    const x = (e.clientX - rect.left);
    const y = (e.clientY - rect.top);
    addBloom(x, y, true);
    for (let i = 0; i < 7; i++) {
      const a = Math.random() * Math.PI * 2;
      const d = 40 + Math.random() * 140;
      addBloom(x + Math.cos(a) * d, y + Math.sin(a) * d, false);
    }
  }, sig);

  hero.addEventListener('pointerleave', () => { mouse.moved = false; }, sig);

  // Scroll purge stays on window
  window.addEventListener('wheel',     () => { purge.active = 1; }, { passive: true, signal: ac.signal });
  window.addEventListener('scroll',    () => { purge.active = 1; }, { passive: true, signal: ac.signal });
  window.addEventListener('touchmove', () => { purge.active = 1; }, { passive: true, signal: ac.signal });

  // Resize
  window.addEventListener('resize', resize, sig);

  /* ── Animation loop ───────────────────────────────────── */
  let rafId = null;
  let lastDrop = 0;

  function frame(t) {
    ctx.globalCompositeOperation = 'source-over';

    // 1. Slowly fade toward bg (paper-drying effect)
    ctx.fillStyle = hexA(PAL.bg, 0.012 * SPEED);
    ctx.fillRect(0, 0, W, H);

    // 2. Drop new bloom on pointer move (throttled)
    if (mouse.moved && t - lastDrop > 45 / SPEED) {
      const dx = mouse.x - mouse.px;
      const dy = mouse.y - mouse.py;
      if (Math.hypot(dx, dy) > 0.0025) {
        addBloom(mouse.x * W, mouse.y * H, false);
        mouse.px = mouse.x;
        mouse.py = mouse.y;
        lastDrop = t;
      }
    }

    // 3. Purge on scroll — flush canvas quickly
    if (purge.active > 0) {
      for (const b of blooms) {
        b.life  = Math.min(b.life,  0.25);
        b.decay = Math.max(b.decay, 0.02);
      }
      ctx.fillStyle = hexA(PAL.bg, 0.25);
      ctx.fillRect(0, 0, W, H);
      purge.active = 0;
    }

    // 4. Draw blooms
    ctx.globalCompositeOperation = 'source-over';
    for (const b of blooms) {
      b.r    += (b.tr - b.r) * 0.04 * SPEED;
      b.life -= b.decay * SPEED;
      if (b.life <= 0) continue;
      const vis = b.life * b.life;
      b.rot += 0.0008 * SPEED;
      blobPath(b, 1.25); ctx.fillStyle = hexA(b.wet, 0.055 * vis); ctx.fill();
      blobPath(b, 0.95); ctx.fillStyle = hexA(b.wet, 0.10  * vis); ctx.fill();
      blobPath(b, 0.55); ctx.fillStyle = hexA(b.wet, 0.16  * vis); ctx.fill();
    }

    // Cull dead blooms
    for (let i = blooms.length - 1; i >= 0; i--) {
      if (blooms[i].life <= 0) blooms.splice(i, 1);
    }

    rafId = requestAnimationFrame(frame);
  }

  /* ── Start ────────────────────────────────────────────── */
  resize();
  seed();
  rafId = requestAnimationFrame(frame);

  /* ── Cleanup (Astro view transitions / page unload) ───── */
  function cleanup() {
    ac.abort();
    if (rafId !== null) cancelAnimationFrame(rafId);
  }

  // Astro view transitions
  document.addEventListener('astro:before-swap', cleanup, { once: true });
  // Plain page unload
  window.addEventListener('pagehide', cleanup, { once: true });
})();
</script>
