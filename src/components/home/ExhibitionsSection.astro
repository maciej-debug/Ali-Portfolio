---
import type { Exhibition } from "../../data/exhibitions";

interface Props {
  exhibitions: Exhibition[];
}

const { exhibitions } = Astro.props;
if (!exhibitions.length) return;
---

<section class="exhibitions" id="exhibitions">
  <div class="exhibitions__inner">

    <!-- Section label -->
    <div class="exhibitions__label-row">
      <p class="about__label">Upcoming</p>
    </div>

    <h2 class="exhibitions__heading">Exhibitions</h2>

    <!-- Exhibition cards -->
    {exhibitions.map((ex) => (
      <article class="exhibition-card">

        <!-- Poster image -->
        <div class="exhibition-card__poster-wrap">
          <img
            class="exhibition-card__poster"
            src={ex.poster}
            alt={`${ex.title} — exhibition poster`}
            loading="lazy"
            decoding="async"
          />
        </div>

        <!-- Details -->
        <div class="exhibition-card__details">

          <div class="exhibition-card__meta-top">
            <span class="exhibition-badge">
              {ex.status === "upcoming" ? "Upcoming" : ex.status === "ongoing" ? "Now on" : "Past"}
            </span>
            {ex.curatedBy && (
              <span class="exhibition-card__curator">{ex.curatedBy}</span>
            )}
          </div>

          <h3 class="exhibition-card__title">{ex.title}</h3>

          {ex.subtitle && (
            <p class="exhibition-card__subtitle">{ex.subtitle}</p>
          )}

          <!-- Artists -->
          <div class="exhibition-card__artists">
            {ex.artists.map((artist, i) => (
              <span class:list={["exhibition-card__artist", artist === "Ali Bachler" && "is-ali"]}>
                {artist}{i < ex.artists.length - 1 ? " · " : ""}
              </span>
            ))}
          </div>

          <!-- Dates -->
          <div class="exhibition-card__dates">
            {ex.dates.map((d) => (
              <div class="exhibition-card__date-row">
                <span class="exhibition-card__date-label">{d.label}</span>
                <span class="exhibition-card__date-value">
                  {d.date}{d.time ? `, ${d.time}` : ""}
                </span>
              </div>
            ))}
          </div>

          <!-- Venue -->
          <div class="exhibition-card__venue">
            {ex.venue.mapUrl ? (
              <a
                href={ex.venue.mapUrl}
                class="exhibition-card__venue-link"
                target="_blank"
                rel="noopener noreferrer"
              >
                <span class="exhibition-card__venue-name">{ex.venue.name}</span>
                {ex.venue.address && (
                  <span class="exhibition-card__venue-address">
                    {ex.venue.address}, {ex.venue.city}
                  </span>
                )}
                <span class="exhibition-card__venue-map">View on map ↗</span>
              </a>
            ) : (
              <div>
                <span class="exhibition-card__venue-name">{ex.venue.name}</span>
                {ex.venue.address && (
                  <span class="exhibition-card__venue-address">
                    {ex.venue.address}, {ex.venue.city}
                  </span>
                )}
              </div>
            )}
          </div>

          <!-- Description -->
          {ex.description && (
            <p class="exhibition-card__description">{ex.description}</p>
          )}

          <!-- CTA row -->
          <div class="exhibition-card__ctas">
            {ex.admission && (
              <span class="exhibition-card__admission">{ex.admission}</span>
            )}
            {ex.rsvpUrl && (
              <a
                href={ex.rsvpUrl}
                class="btn btn--primary"
                target="_blank"
                rel="noopener noreferrer"
              >
                RSVP <span aria-hidden="true">→</span>
              </a>
            )}
          </div>

        </div>
      </article>
    ))}

  </div>
</section>

<style>
  .exhibitions {
    padding: var(--section-v) var(--section-h);
    background-color: var(--bg-100);
  }

  .exhibitions__inner {
    max-width: var(--max-width);
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    gap: 48px;
  }

  .exhibitions__label-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .exhibitions__heading {
    font-family: var(--font-display);
    font-size: clamp(34px, 4vw, 50px);
    font-weight: 400;
    line-height: 1;
    letter-spacing: -0.04em;
    margin-top: -28px; /* tighten gap after label */
  }

  /* ── Exhibition Card ───────────────────────────────── */

  .exhibition-card {
    display: grid;
    grid-template-columns: 440px 1fr;
    gap: 72px;
    align-items: start;
    padding-top: 48px;
  }

  .exhibition-card__poster-wrap {
    position: sticky;
    top: calc(var(--nav-height) + 24px);
    border-radius: 2px;
    overflow: hidden;
    box-shadow: 0 4px 32px rgba(42, 31, 24, 0.10);
  }

  .exhibition-card__poster {
    width: 100%;
    height: auto;
    display: block;
  }

  /* ── Details column ───────────────────────────────── */

  .exhibition-card__details {
    display: flex;
    flex-direction: column;
    gap: 28px;
    padding-top: 8px;
  }

  .exhibition-card__meta-top {
    display: flex;
    align-items: center;
    gap: 14px;
    flex-wrap: wrap;
  }

  .exhibition-badge {
    display: inline-block;
    padding: 3px 10px;
    border-radius: 100px;
    font-size: 10px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    background-color: var(--accent);
    color: #fff;
  }

  .exhibition-card__curator {
    font-size: 12px;
    color: var(--text-200);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .exhibition-card__title {
    font-family: var(--font-display);
    font-size: clamp(32px, 4vw, 52px);
    font-weight: 400;
    line-height: 1.0;
    letter-spacing: -0.05em;
    color: var(--text);
  }

  .exhibition-card__subtitle {
    font-size: 15px;
    font-weight: 300;
    color: var(--text-200);
    line-height: 1.5;
    margin-top: -16px;
  }

  .exhibition-card__artists {
    font-size: 14px;
    color: var(--text-100);
    line-height: 1.6;
  }

  .exhibition-card__artist.is-ali {
    font-weight: 500;
    color: var(--text);
  }

  /* ── Dates block ────────────────────────────────────── */

  .exhibition-card__dates {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 24px;
    background-color: var(--bg);
    border-radius: 2px;
    border: 1px solid var(--border);
  }

  .exhibition-card__date-row {
    display: flex;
    gap: 16px;
    font-size: 14px;
    line-height: 1.4;
  }

  .exhibition-card__date-label {
    color: var(--text-200);
    min-width: 180px;
    flex-shrink: 0;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    padding-top: 1px;
  }

  .exhibition-card__date-value {
    color: var(--text);
    font-weight: 400;
  }

  /* ── Venue ───────────────────────────────────────────── */

  .exhibition-card__venue {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .exhibition-card__venue-link {
    display: flex;
    flex-direction: column;
    gap: 3px;
    text-decoration: none;
    color: inherit;
  }

  .exhibition-card__venue-name {
    font-size: 15px;
    font-weight: 500;
    color: var(--text);
    display: block;
  }

  .exhibition-card__venue-address {
    font-size: 14px;
    color: var(--text-200);
    display: block;
  }

  .exhibition-card__venue-map {
    font-size: 12px;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.07em;
    display: block;
    margin-top: 4px;
    transition: opacity 0.2s ease;
  }

  .exhibition-card__venue-link:hover .exhibition-card__venue-map {
    opacity: 0.7;
  }

  /* ── Description ─────────────────────────────────────── */

  .exhibition-card__description {
    font-size: 15px;
    font-weight: 300;
    color: var(--text-100);
    line-height: 1.75;
    border-left: 2px solid var(--border);
    padding-left: 18px;
  }

  /* ── CTAs ─────────────────────────────────────────────── */

  .exhibition-card__ctas {
    display: flex;
    align-items: center;
    gap: 20px;
    flex-wrap: wrap;
  }

  .exhibition-card__admission {
    font-size: 13px;
    font-weight: 500;
    color: var(--text-100);
    text-transform: uppercase;
    letter-spacing: 0.07em;
  }

  /* ── Responsive ────────────────────────────────────────── */

  @media (max-width: 1024px) {
    .exhibition-card {
      grid-template-columns: 360px 1fr;
      gap: 48px;
    }

    .exhibition-card__date-label {
      min-width: 140px;
    }
  }

  @media (max-width: 800px) {
    .exhibition-card {
      grid-template-columns: 1fr;
      gap: 36px;
    }

    .exhibition-card__poster-wrap {
      position: static;
      max-width: 480px;
    }
  }

  @media (max-width: 640px) {
    .exhibition-card__date-row {
      flex-direction: column;
      gap: 3px;
    }

    .exhibition-card__date-label {
      min-width: auto;
    }

    .exhibition-card__ctas {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
