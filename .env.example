# ─── Sanity CMS ───────────────────────────────────────────────────────────────
#
# Copy this file to .env and fill in your values.
# If SANITY_PROJECT_ID is absent the site uses local data from
# src/data/artworks.ts automatically — no changes needed.
#
# Find your project ID at https://sanity.io/manage
# ──────────────────────────────────────────────────────────────────────────────

# Required — your Sanity project ID (e.g. "abc123de")
SANITY_PROJECT_ID=

# Optional — dataset name (default: "production")
SANITY_DATASET=production

# Optional — Sanity Content API version (default: "2024-01-01")
SANITY_API_VERSION=2024-01-01

# Optional — read token for private datasets or draft previews
# Generate one at https://sanity.io/manage → API → Tokens
# Leave blank for public datasets
SANITY_TOKEN=
